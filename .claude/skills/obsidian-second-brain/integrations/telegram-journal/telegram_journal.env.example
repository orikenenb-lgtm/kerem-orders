# Telegram journal config - copy this to your real config file and fill it in:
#   cp telegram_journal.env.example ~/.config/obsidian-second-brain/telegram_journal.env
#   chmod 600 ~/.config/obsidian-second-brain/telegram_journal.env
# (or set TELEGRAM_JOURNAL_CONFIG to point somewhere else).
# NEVER commit the filled-in file - it holds your real secrets.

# From @BotFather: create a bot, paste its token here.
TELEGRAM_JOURNAL_BOT_TOKEN=

# Used to transcribe voice notes (OpenAI Whisper).
OPENAI_API_KEY=

# Used to tidy text and read images (Claude). Must be a key with credit/billing.
ANTHROPIC_API_KEY=

# Absolute path to your Obsidian vault.
VAULT_PATH=/Users/you/path/to/Your Vault

# Optional: your name, so images/captures addressed to you route to the daily note
# (instead of a person note for yourself), and the bot never makes a note for you. Leave blank to skip.
VAULT_OWNER=

# Optional: proper nouns to bias voice transcription (comma-separated), so Whisper spells
# names right (e.g. people, companies, projects you talk about). Leave blank to skip.
WHISPER_HINT=

# Optional, for link routing: when you send a YouTube/X/article link, the bot runs the
# matching obsidian-second-brain research command (/youtube, /x-read, /research) from your
# clone of the skill repo. Path to that clone, and the uv binary if it is not on the
# launchd/cron PATH.
OBSIDIAN_SKILL_REPO=~/obsidian-second-brain
UV_BIN=uv
