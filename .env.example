# ===== Kerem Orders — Backend =====
# העתק קובץ זה ל-.env ומלא ערכים אמיתיים. לעולם אל תכניס את .env ל-git!

# סביבת ריצה: dev | production
ENVIRONMENT=dev

# --- Supabase (Phase 1) ---
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Rivhit Online (Phase 2) — הטוקן נשאר בבקנד בלבד! ---
RIVHIT_API_TOKEN=
RIVHIT_API_BASE_URL=https://online.rivhit.co.il/api/v3

# --- סנכרון אוטומטי: true בפרודקשן בלבד ---
SYNC_ENABLED=false
SYNC_INTERVAL_HOURS=4

# --- התראות (Phase 5) ---
RESEND_API_KEY=
EMAIL_FROM=Kerem Orders <onboarding@resend.dev>
ADMIN_NOTIFICATION_EMAIL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- CORS: דומיינים מורשים, מופרדים בפסיק ---
# מופרד בפסיקים; דומיין ה-Vercel האמיתי כבר בברירת המחדל בקוד
ALLOWED_ORIGINS=https://ai-assistant-seven-theta.vercel.app,http://localhost:5173
